---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Full URL for canonical and OG (default: current page URL on site) */
  canonicalURL?: string | URL;
  /** OG/Twitter image URL (absolute). Defaults to profile image. */
  ogImage?: string;
  /** For blog posts: article published time */
  pubDate?: Date;
  /** For blog posts: article modified time */
  modDate?: Date;
  /** Noindex this page */
  noindex?: boolean;
  /** Optional JSON-LD script (string) to inject before </head> */
  jsonLd?: string;
  /** Article tags for OG article:tag meta */
  tags?: string[];
}

const AUTHOR = 'Devansh Purwar';
const DEFAULT_DESC = `${AUTHOR} — Software Developer. Portfolio, blog, and notes.`;

const { title, description = DEFAULT_DESC, canonicalURL, ogImage, pubDate, modDate, noindex = false, jsonLd, tags = [] } = Astro.props;

const site = Astro.site ?? new URL('https://devansh-purwar.github.io');
const canonical = canonicalURL ? new URL(canonicalURL) : new URL(Astro.url.pathname, site);
const imageURL = ogImage ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).href) : new URL('/2.JPG', site).href;
const type = pubDate ? 'article' : 'website';

const fullTitle = title === AUTHOR ? title : `${title} — ${AUTHOR}`;

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: AUTHOR,
  alternateName: ['devansh purwar', 'Devansh', 'devanshpurwar'],
  description: description,
  url: site.href,
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: AUTHOR,
    url: site.href,
    sameAs: [
      'https://github.com/devansh-purwar',
      'https://linkedin.com/in/devansh-purwar',
    ],
  },
});
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={AUTHOR} />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:alt" content={`${AUTHOR} — ${title}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={AUTHOR} />
    <meta property="og:locale" content="en_US" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {modDate && <meta property="article:modified_time" content={modDate.toISOString()} />}
    {pubDate && <meta property="article:author" content={AUTHOR} />}
    {pubDate && <meta property="article:section" content="Technology" />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={`${AUTHOR} — ${title}`} />

    <meta name="theme-color" content="#FFFBF5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${AUTHOR} — Blog RSS`} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={websiteSchema} />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
