---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const site = Astro.site?.href ?? 'https://devansh-purwar.github.io';
const canonicalURL = `${site}/blog/${post.slug}/`;
---
<BaseLayout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  canonicalURL={canonicalURL}
  pubDate={post.data.pubDate}
  modDate={post.data.updatedDate}
  ogImage={`${site}/2.JPG`}
>
  <article class="page post">
    <div class="container container-wide">
      <header class="post-header section">
        <h1 class="post-title">{post.data.title}</h1>
        <time datetime={post.data.pubDate.toISOString()} class="post-date">
          {post.data.pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </header>
      <div class="post-body">
        <Content />
      </div>
      <p class="back-link"><a href="/blog">← All posts</a></p>
    </div>
  </article>
</BaseLayout>

<style>
  .page { padding-bottom: 2rem; }
  .post-header { padding-bottom: 1rem; }
  .post-title { font-size: clamp(1.5rem, 4vw, 2rem); margin-bottom: 0.5rem; }
  .post-date { font-size: 0.9375rem; color: var(--text-muted); }
  .post-body {
    line-height: 1.75;
    max-width: 100%;
  }
  .post-body :global(p) { margin-bottom: 1rem; }
  .post-body :global(h2) {
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }
  .post-body :global(h2:first-of-type) { margin-top: 0; }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .post-body :global(li) { margin-bottom: 0.35rem; }
  /* Code blocks */
  .post-body :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .post-body :global(pre code) {
    font-family: var(--font-mono);
    font-size: inherit;
    background: none;
    padding: 0;
    border: none;
  }
  /* Inline code */
  .post-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.2em 0.45em;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
  }
  /* Tables */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9375rem;
    table-layout: fixed;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.6rem 0.75rem;
    text-align: left;
    vertical-align: top;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .post-body :global(th) {
    background: var(--surface);
    font-weight: 600;
    color: var(--accent);
  }
  .post-body :global(strong) { font-weight: 600; color: var(--text); }
  .back-link { margin-top: 2rem; }
</style>
