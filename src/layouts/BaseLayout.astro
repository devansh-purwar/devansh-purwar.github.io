---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Full URL for canonical and OG (default: current page URL on site) */
  canonicalURL?: string | URL;
  /** OG/Twitter image URL (absolute). Defaults to profile image. */
  ogImage?: string;
  /** For blog posts: article published time */
  pubDate?: Date;
  /** For blog posts: article modified time */
  modDate?: Date;
  /** Noindex this page */
  noindex?: boolean;
  /** Optional JSON-LD script (string) to inject before </head> */
  jsonLd?: string;
}

const { title, description = "Devansh Purwar — Software Developer. Portfolio, blog, and notes.", canonicalURL, ogImage, pubDate, modDate, noindex = false, jsonLd } = Astro.props;

const site = Astro.site ?? new URL('https://devansh-purwar.github.io');
const canonical = canonicalURL ? new URL(canonicalURL) : new URL(Astro.url.pathname, site);
const imageURL = ogImage ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).href) : new URL('/2.JPG', site).href;
const type = pubDate ? 'article' : 'website';

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Devansh Purwar',
  description: description,
  url: site.href,
  author: {
    '@type': 'Person',
    name: 'Devansh Purwar',
    url: site.href,
    sameAs: ['https://github.com/devansh-purwar', 'https://linkedin.com/in/devansh-purwar'],
  },
});
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content="Devansh Purwar" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {modDate && <meta property="article:modified_time" content={modDate.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <meta name="theme-color" content="#FFFBF5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={websiteSchema} />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
