---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const AUTHOR = 'Devansh Purwar';
const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await post.render();
const siteRaw = Astro.site?.href ?? 'https://devansh-purwar.github.io';
const site = siteRaw.replace(/\/$/, '');
const canonicalURL = `${site}/blog/${post.slug}/`;
const ogImage = post.data.ogImage ? `${site}${post.data.ogImage}` : `${site}/2.JPG`;
const tags = post.data.tags ?? [];

const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 225));

const blogPostSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description ?? post.data.title,
  url: canonicalURL,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: AUTHOR,
    url: site,
  },
  publisher: {
    '@type': 'Person',
    name: AUTHOR,
    url: site,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
  image: ogImage,
  wordCount: wordCount,
  inLanguage: 'en',
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
  ...(tags.length > 0 && { articleSection: tags[0] }),
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: site,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${site}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: canonicalURL,
    },
  ],
});

const allSchemas = `${blogPostSchema}</script><script type="application/ld+json">${breadcrumbSchema}`;
---
<BaseLayout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  canonicalURL={canonicalURL}
  pubDate={post.data.pubDate}
  modDate={post.data.updatedDate}
  ogImage={ogImage}
  jsonLd={allSchemas}
  tags={tags}
>
  <article class="page post">
    <div class="container container-wide">
      <header class="post-header section">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()} class="post-date">
            {post.data.pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="post-reading-time">{readingTime} min read</span>
        </div>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="post-body">
        <Content />
      </div>
      <footer class="post-footer">
        <p class="post-author">Written by <strong>{AUTHOR}</strong></p>
        <p class="back-link"><a href="/blog">← All posts</a></p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .page { padding-bottom: 2rem; }
  .post-header { padding-bottom: 1rem; }
  .post-title { font-size: clamp(1.5rem, 4vw, 2rem); margin-bottom: 0.5rem; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-date { font-size: 0.9375rem; color: var(--text-muted); }
  .post-reading-time {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .post-reading-time::before {
    content: '·';
    margin-right: 1rem;
  }
  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }
  .post-tag {
    font-size: 0.8125rem;
    padding: 0.2rem 0.6rem;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 0.25rem;
    border: 1px solid var(--accent);
  }
  .post-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .post-author {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .post-body {
    line-height: 1.75;
    max-width: 100%;
  }
  .post-body :global(p) { margin-bottom: 1rem; }
  .post-body :global(h2) {
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }
  .post-body :global(h2:first-of-type) { margin-top: 0; }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .post-body :global(li) { margin-bottom: 0.35rem; }
  /* Code blocks */
  .post-body :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .post-body :global(pre code) {
    font-family: var(--font-mono);
    font-size: inherit;
    background: none;
    padding: 0;
    border: none;
  }
  /* Inline code */
  .post-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.2em 0.45em;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
  }
  /* Tables */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9375rem;
    table-layout: fixed;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.6rem 0.75rem;
    text-align: left;
    vertical-align: top;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .post-body :global(th) {
    background: var(--surface);
    font-weight: 600;
    color: var(--accent);
  }
  .post-body :global(strong) { font-weight: 600; color: var(--text); }
  .back-link { margin-top: 2rem; }
</style>
