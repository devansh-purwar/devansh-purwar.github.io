---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { profile, aboutBlurb, projects } from '../data/profile';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---
<BaseLayout title={profile.name} description={aboutBlurb}>
  <article class="page">
    <div class="container container-wide">
      <!-- Hero: name + short intro + links to about/now (Aman-style) -->
      <header class="hero section">
        <div class="hero-heading-row">
          <h1 class="hero-title">{profile.name}</h1>
          <a href="/rss.xml" class="rss-link" aria-label="RSS Feed" title="RSS Feed">
            <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z" />
              <path d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z" />
              <circle cx="6" cy="18" r="2" />
            </svg>
            <span class="rss-text">RSS Feed</span>
          </a>
        </div>
        <p class="hero-tagline">{profile.tagline}</p>
        <div class="hero-text">
          <p>
            I'm a Software Engineer with 2+ years of experience, currently at CommerceIQ. I build scalable microservices, automation, and cloud infrastructure. I enjoy solving complex problems and have a strong foundation in algorithms and system design.
          </p>
          <p>
            See what I'm up to on my <a href="/now">now</a> page or learn more on my <a href="/about">about</a> page.
          </p>
        </div>
        <div class="hero-links">
          <a href={profile.cvUrl} class="btn btn-primary" target="_blank" rel="noopener">Download CV</a>
          <a href="/about#contact" class="btn">Contact</a>
        </div>
      </header>

      <!-- Recent Posts -->
      {recentPosts.length > 0 && (
        <section class="section">
          <hr class="section-hr" aria-hidden="true" />
          <h2 class="section-heading">Recent Posts</h2>
          <ul class="post-list">
            {recentPosts.map((post) => (
              <li class="post-list-item">
                <div class="post-list-content">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                  {post.data.description && (
                    <p class="post-list-desc">{post.data.description}</p>
                  )}
                </div>
                <time datetime={post.data.pubDate.toISOString()} class="post-list-date">
                  Published: {post.data.pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </li>
            ))}
          </ul>
          <p class="section-more">
            <a href="/blog" class="link-with-arrow">
              See all {allPosts.length} posts
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" /></svg>
            </a>
          </p>
        </section>
      )}

      <!-- Projects teaser (single card like Aman's) -->
      <section class="section">
        <hr class="section-hr" aria-hidden="true" />
        <h2 class="section-heading">Projects</h2>
        <a href="/projects" class="projects-card">
          <span class="projects-card-text">View all projects</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" /></svg>
        </a>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    padding-bottom: 2rem;
  }
  .hero {
    padding-top: 3rem;
  }
  .hero-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: 0.25rem;
  }
  .hero-tagline {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .hero-text {
    max-width: 56ch;
  }
  .hero-text p {
    margin-bottom: 1rem;
    color: var(--text);
  }
  .hero-text p:last-of-type {
    margin-bottom: 1.5rem;
  }
  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .hero-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .rss-link:hover {
    color: var(--accent);
  }
  .rss-icon {
    flex-shrink: 0;
    color: var(--accent);
  }
  .section-hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 2rem;
  }
  .link-with-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .link-with-arrow svg {
    flex-shrink: 0;
  }
  .projects-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text);
    transition: border-color 0.2s, background 0.2s;
  }
  .projects-card:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .projects-card-text {
    font-weight: 500;
    color: var(--accent);
  }
  .projects-card:hover .projects-card-text {
    color: var(--text);
  }
  .arrow-icon {
    flex-shrink: 0;
    color: var(--accent);
  }
  .post-list li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .post-list-content {
    flex: 1;
    min-width: 0;
  }
  .post-list a {
    font-weight: 500;
  }
  .post-list-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0.25rem 0 0;
    line-height: 1.5;
  }
  .post-list-date {
    font-size: 0.875rem;
    color: var(--text-muted);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .section-more {
    margin-top: 0.75rem;
  }
</style>
